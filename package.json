{
  "name": "leetcode-cli",
  "version": "0.1.0",
  "description": "A minimal LeetCode CLI for terminal-driven problem solving",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "leetcode": "dist/index.js",
    "leetcode-cli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "keywords": [
    "leetcode",
    "cli",
    "typescript"
  ],
  "author": "Steven Li",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "conf": "^15.1.0",
    "diff": "^9.0.0",
    "ora": "^9.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
